# バックエンド設定
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
FILE_RETENTION_HOURS=24

# JPEG変換設定
DEFAULT_QUALITY=85
MAX_DELTA_E=2.0

# CORS設定（本番環境では許可するオリジンを明示的に指定する）
# 例: CORS_ORIGINS=["https://example.com","https://www.example.com"]
# CORS_ORIGINS=["*"]

# フロントエンド設定（Docker Compose 内通信用）
VITE_API_URL=http://backend:8000
VITE_WS_URL=ws://backend:8000
